# Database — defaults to local SQLite (easy dev start)
# Switch to postgres: postgresql://user:password@localhost/geofence
DATABASE_URL=sqlite:///./geofence.db

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect — for merchant OAuth flow
# Get from https://dashboard.stripe.com/settings/connect
STRIPE_CLIENT_ID=ca_...

# Optional: a default Stripe Price ID to attach to payment links
# Create one in Stripe Dashboard → Products
DEFAULT_PRICE_ID=price_...

# Anthropic — for Claude-powered decision agent (optional, falls back to rule engine)
ANTHROPIC_API_KEY=sk-ant-...
